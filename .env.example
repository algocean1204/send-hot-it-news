# === news-pulse 환경변수 ===
# 이 파일을 복사하여 .env 파일을 만들고 실제 값을 입력하세요.
# cp .env.example .env

# --------------------------------------------------
# 텔레그램 설정
# --------------------------------------------------

# 텔레그램 봇 토큰 (BotFather에서 발급)
BOT_TOKEN=your_bot_token_here

# 관리자 텔레그램 chat_id (메시지 수신 대상)
ADMIN_CHAT_ID=your_chat_id_here

# --------------------------------------------------
# 데이터베이스 설정
# --------------------------------------------------

# SQLite DB 파일 경로 (~ 경로 지원)
DB_PATH=~/.news-pulse/news_pulse.db

# --------------------------------------------------
# Ollama 설정
# --------------------------------------------------

# Ollama API 엔드포인트 (기본값: 로컬)
OLLAMA_ENDPOINT=http://localhost:11434

# APEX I-Compact 모델 이름 (Ollama 레지스트리 등록명)
# 실제 모델명은 setup.sh 실행 후 `ollama list`로 확인하세요.
APEX_MODEL_NAME=apex-i-compact

# Kanana-2-30B 모델 이름 (Ollama 레지스트리 등록명)
# 실제 모델명은 setup.sh 실행 후 `ollama list`로 확인하세요.
KANANA_MODEL_NAME=kanana-2-30b

# --------------------------------------------------
# 메모리 임계값 설정
# --------------------------------------------------

# 가용 메모리 임계값 (GB) -- 이 값 미만이면 Claude CLI 폴백 사용
MEMORY_THRESHOLD_GB=26.0

# --------------------------------------------------
# 타임존 설정
# --------------------------------------------------

# 한국 표준시 고정 (launchd plist와 이중 고정)
TZ=Asia/Seoul
